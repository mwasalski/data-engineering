    "from datetime import datetime\n",
    "\n",
    "# today's date\n",
    "today = datetime(2024, 10, 15)\n",
    "\n",
    "# last day of the year\n",
    "end_of_year = datetime(2024, 12, 31)\n",
    "\n",
    "# calculate the difference\n",
    "days_left = (end_of_year - today).days\n",
    "days_left\n"
   ]
  }
